generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== MODELS ====================

model User {
  id         String   @id @default(uuid())
  telegramId String   @unique
  firstName  String   @default("")
  lastName   String   @default("")
  username   String   @default("")
  photoUrl   String   @default("")
  phone      String?  @unique
  role       String?
  onboarded  Boolean  @default(false)
  language   String   @default("uz")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company    Company?
  influencer Influencer?

  @@map("users")
}

model Company {
  id          String   @id @default(uuid())
  userId      String   @unique
  name        String
  industry    String
  logo        String   @default("")
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ads     Ad[]
  reviews Review[] @relation("CompanyReviews")

  @@map("companies")
}

model Influencer {
  id          String   @id @default(uuid())
  userId      String   @unique
  name        String
  bio         String   @default("")
  category    String   @default("")
  socialLinks String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
  reviews      Review[]      @relation("InfluencerReviews")

  @@map("influencers")
}

model Ad {
  id              String   @id @default(uuid())
  companyId       String
  title           String
  description     String
  images          String   @default("[]")
  industry        String   @default("")
  videoFormat     String   @default("ANY")
  faceType        String   @default("ANY")
  platforms       String   @default("[]")
  influencerCount Int      @default(3)
  adType          String   @default("BARTER")
  barterItem      String   @default("")
  payment         Float    @default(0)
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]

  @@map("ads")
}

model Application {
  id           String   @id @default(uuid())
  adId         String
  influencerId String
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ad          Ad           @relation(fields: [adId], references: [id], onDelete: Cascade)
  influencer  Influencer   @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  reviews     Review[]
  submissions Submission[]

  @@unique([adId, influencerId])
  @@map("applications")
}

model Submission {
  id            String   @id @default(uuid())
  applicationId String
  videoUrl      String
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("submissions")
}

model Review {
  id            String   @id @default(uuid())
  applicationId String
  companyId     String
  influencerId  String
  type          String
  rating        Int
  comment       String   @default("")
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  company     Company     @relation("CompanyReviews", fields: [companyId], references: [id], onDelete: Cascade)
  influencer  Influencer  @relation("InfluencerReviews", fields: [influencerId], references: [id], onDelete: Cascade)

  @@map("reviews")
}
